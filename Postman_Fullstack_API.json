                  "    pm.expect(responseJson).to.have.property('data');",
                  "    pm.expect(responseJson.data).to.have.property('id');",
                  "    pm.expect(responseJson.data).to.have.property('username');",
                  "    pm.expect(responseJson.data).to.have.property('email');",
                  "});"
