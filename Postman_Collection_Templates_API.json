{
  "info": {
    "_postman_id": "template-api-collection",
    "name": "Template API Collection",
    "description": "Collection untuk testing Template API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Templates",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response has success property set to true', function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.have.property('success', true);",
              "});",
              "",
              "pm.test('Response contains data array', function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.have.property('data');",
              "    pm.expect(responseJson.data).to.be.an('array');",
              "});",
              "",
              "pm.test('Response contains pagination info', function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.have.property('pagination');",
              "    pm.expect(responseJson.pagination).to.have.property('page');",
              "    pm.expect(responseJson.pagination).to.have.property('limit');",
              "    pm.expect(responseJson.pagination).to.have.property('total');",
              "    pm.expect(responseJson.pagination).to.have.property('totalPages');",
              "});",
              "",
              "// Save first template ID if exists",
              "const responseJson = pm.response.json();",
              "if (responseJson.data.length > 0) {",
              "    pm.environment.set('template_id', responseJson.data[0].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/templates?page=1&limit=10",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "templates"
          ],
          "query": [
            {
              "key": "page",
              "value": "1",
              "disabled": false
            },
            {
              "key": "limit",
              "value": "10",
              "disabled": false
            }
          ]
        }
      }
    },
    {
      "name": "Get Templates with Search",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Search filter works', function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson.success).to.equal(true);",
              "    // Check if returned templates contain the search keyword",
              "    const searchTerm = pm.variables.get('search_term') || 'sneat';",
              "    responseJson.data.forEach(function(template) {",
              "        pm.expect(template.title.toLowerCase()).to.include(searchTerm.toLowerCase());",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/templates?search=sneat&page=1&limit=10",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "templates"
          ],
          "query": [
            {
              "key": "search",
              "value": "sneat",
              "disabled": false
            },
            {
              "key": "page",
              "value": "1",
              "disabled": false
            },
            {
              "key": "limit",
              "value": "10",
              "disabled": false
            }
          ]
        }
      }
    },
    {
      "name": "Get Templates Page 2",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Pagination page is correct', function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson.pagination.page).to.equal(2);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/templates?page=2&limit=10",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "templates"
          ],
          "query": [
            {
              "key": "page",
              "value": "2",
              "disabled": false
            },
            {
              "key": "limit",
              "value": "10",
              "disabled": false
            }
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "template_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "search_term",
      "value": "sneat",
      "type": "string"
    }
  ]
}
